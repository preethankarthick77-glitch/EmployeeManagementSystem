<%- include('partials/header') %>
<div class="container" style="max-width: 500px;">
    <div class="card card-body shadow">
        <h4>Edit Department Object</h4>
        <% if (error) { %> <div class="alert alert-danger"><%= error %></div> <% } %>
        <form action="/departments/edit/<%= department.id %>" method="POST">
            <div class="mb-3">
                <label>Department Name</label>
                <input type="text" name="name" value="<%= department.name %>" class="form-control" required>
            </div>
            <div class="mb-3">
                <label>Description Details</label>
                <textarea name="description" class="form-control" rows="3"><%= department.description %></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success w-100">Save Modifications</button>
                <a href="/departments" class="btn btn-light w-100">Cancel</a>
            </div>
        </form>
    </div>
</div>
<%- include('partials/footer') %>
